# ============================================================
# Thamili App — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ============================================================

# --- Supabase (required) ------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Stripe (required for payments) ------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# --- Mapbox (required for maps) ----------------------------
MAPBOX_PUBLIC_KEY=pk.eyJ1IjoieW91cnVzZXJuYW1lIiwiYSI6InNvbWVrZXkifQ.signature

# ⚠️  SECURITY: This is a Mapbox SECRET token (sk. prefix).
# Only needed at EAS build time — never bundled in the app.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.eyJ1IjoieW91cnVzZXJuYW1lIiwiYSI6InNvbWVrZXkifQ.signature

# --- Vercel API (required for push notifications) ----------
EXPO_PUBLIC_VERCEL_API_URL=https://your-project.vercel.app

# --- Internal API Secret -----------------------------------
# Shared between this app and the Vercel send-push function.
# Generate with: openssl rand -hex 32
# Set the SAME value in Vercel dashboard → Settings → Environment Variables
INTERNAL_API_SECRET=your_generated_secret_here

# ⚠️  SECURITY: SUPABASE_SERVICE_ROLE_KEY bypasses ALL Row Level Security.
# Only set this in Vercel environment variables — NEVER in this file for production.
# For local Vercel CLI use only:
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
