    "start:offline": "expo start --offline",
    "start:offline-clear": "expo start --offline --clear",
    "start:no-check": "EXPO_NO_DOTENV=1 expo start --no-dev --minify",
    "start:skip-validation": "EXPO_SKIP_NATIVE_VERSION_CHECK=1 expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
